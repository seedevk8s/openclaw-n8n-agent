  <diagram id="overview" name="⭐ 전체 구조 (한눈에)">
    <mxGraphModel dx="1000" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="오픈클로 ↔ 디스코드  전체 구조 (요약)" style="text;html=1;align=center;verticalAlign=middle;fontSize=24;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="20" width="800" height="50" as="geometry" />
        </mxCell>
        <mxCell id="prep" value="🔧 준비 단계&#10;(최초 1회)&#10;&#10;디스코드 개발자 포털&#10;에서 토큰 발급" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=16;fontStyle=1;verticalAlign=middle;align=center;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="220" width="260" height="160" as="geometry" />
        </mxCell>
        <mxCell id="discord" value="💬 디스코드&#10;&#10;사용자가 메시지를&#10;주고받는 곳&#10;(서버/채널)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=16;fontStyle=1;verticalAlign=middle;align=center;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="380" y="220" width="260" height="160" as="geometry" />
        </mxCell>
        <mxCell id="openclaw" value="🧠 오픈클로&#10;&#10;메시지를 받아서&#10;AI로 답변을 만드는&#10;프로그램 (WSL)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=16;fontStyle=1;verticalAlign=middle;align=center;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="700" y="220" width="260" height="160" as="geometry" />
        </mxCell>
        <mxCell id="a1" value="토큰 등록 (최초 1회)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=13;endArrow=block;strokeColor=#B85450;strokeWidth=3;fontColor=#B85450;dashed=1;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="prep" target="openclaw">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="190" y="100" />
              <mxPoint x="830" y="100" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="a2" value="메시지 실시간 송수신 (항상 켜져 있어야 함)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=13;startArrow=block;endArrow=block;strokeColor=#82B366;strokeWidth=3;fontColor=#82B366;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="discord" target="openclaw">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="510" y="440" />
              <mxPoint x="830" y="440" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="note" value="자세한 단계별 그림은 아래 탭에서 확인하세요&#10;&#10;① 준비 단계 (최초 1회)   |   ② 실행 흐름 (메시지마다 매번)   |   텔레그램/디스코드 비교" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=14;fontStyle=0;verticalAlign=middle;align=center;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="510" width="900" height="90" as="geometry" />
        </mxCell>
      </root>
