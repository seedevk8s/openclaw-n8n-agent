        <mxCell id="r5m2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=12;endArrow=block;strokeColor=#9673A6;strokeWidth=2;fontColor=#9673A6;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.75;entryY=0;entryDx=0;entryDy=0;labelBackgroundColor=#ffffff;dashed=1;" edge="1" parent="1" source="agent2" target="model_common">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="integration" value="공통 연동 (예정) : Gmail · 캘린더 · 드라이브" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=14;fontStyle=1;verticalAlign=middle;align=center;spacing=6;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="1155" width="860" height="70" as="geometry" />
        </mxCell>
        <mxCell id="r6a" value="필요 시 연동" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;fontSize=12;endArrow=block;strokeColor=#999999;strokeWidth=2;fontColor=#999999;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.4;entryY=0;entryDx=0;entryDy=0;labelBackgroundColor=#ffffff;dashed=1;" edge="1" parent="1" source="model_common" target="integration">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="prep-real" name="① 준비 단계 (실제 진행)">
    <mxGraphModel dx="1000" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="875" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="준비 단계 : 실제로 했던 것 그대로" style="text;html=1;align=center;verticalAlign=middle;fontSize=22;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="820" height="50" as="geometry" />
        </mxCell>
        <mxCell id="s0" value="1. 디스코드 개발자 포털 접속 → '신규 애플리케이션' → 이름 'OpenClaw' 로 생성" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=14;fontStyle=0;verticalAlign=middle;align=left;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="100" width="780" height="100" as="geometry" />
        </mxCell>
        <mxCell id="s1" value="2. Bot 메뉴 → 유저네임 자동 지정됨 (bot20260706) → '토큰 초기화' → 토큰 복사" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=14;fontStyle=0;verticalAlign=middle;align=left;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="235" width="780" height="100" as="geometry" />
        </mxCell>
        <mxCell id="a1" value="" style="edgeStyle=none;rounded=0;html=1;endArrow=block;exitX=0.5;exitY=1;entryX=0.5;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;strokeColor=#B85450;strokeWidth=3;" edge="1" parent="1" source="s0" target="s1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s2" value="3. Privileged Gateway Intents : Server Members Intent ON, Message Content Intent ON (Presence는 OFF 유지)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=14;fontStyle=0;verticalAlign=middle;align=left;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="370" width="780" height="100" as="geometry" />
        </mxCell>
        <mxCell id="a2" value="" style="edgeStyle=none;rounded=0;html=1;endArrow=block;exitX=0.5;exitY=1;entryX=0.5;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;strokeColor=#B85450;strokeWidth=3;" edge="1" parent="1" source="s1" target="s2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s3" value="4. OAuth2 → URL Generator → scope: bot 체크 → 권한 4개 체크 (메시지 보내기 / 링크 임베드 / 파일 첨부 / 메시지 기록 보기)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=14;fontStyle=0;verticalAlign=middle;align=left;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="505" width="780" height="100" as="geometry" />
        </mxCell>
        <mxCell id="a3" value="" style="edgeStyle=none;rounded=0;html=1;endArrow=block;exitX=0.5;exitY=1;entryX=0.5;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;strokeColor=#B85450;strokeWidth=3;" edge="1" parent="1" source="s2" target="s3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s4" value="5. 생성된 초대 URL 접속 → 테스트용 서버 'OpenClaw-Test' 를 새로 만들어서 그 서버에 초대 → '성공!' 화면 확인" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=14;fontStyle=0;verticalAlign=middle;align=left;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="640" width="780" height="100" as="geometry" />
        </mxCell>
        <mxCell id="a4" value="" style="edgeStyle=none;rounded=0;html=1;endArrow=block;exitX=0.5;exitY=1;entryX=0.5;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;strokeColor=#B85450;strokeWidth=3;" edge="1" parent="1" source="s3" target="s4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="onboard-real" name="② 오픈클로 온보딩 (실제 진행)">
    <mxGraphModel dx="1000" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="1145" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="오픈클로 설치 · 온보딩 : 실제로 했던 것 그대로" style="text;html=1;align=center;verticalAlign=middle;fontSize=22;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="820" height="50" as="geometry" />
        </mxCell>
        <mxCell id="s0" value="1. WSL 안에 배포판 'openclaw01' (Ubuntu-24.04 기반) 에서 openclaw onboard 실행" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=14;fontStyle=0;verticalAlign=middle;align=left;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="100" width="780" height="100" as="geometry" />
        </mxCell>
        <mxCell id="s1" value="2. 'Select channel (QuickStart)' → 'Discord (Bot API)' 선택" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=14;fontStyle=0;verticalAlign=middle;align=left;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="235" width="780" height="100" as="geometry" />
        </mxCell>
        <mxCell id="a1" value="" style="edgeStyle=none;rounded=0;html=1;endArrow=block;exitX=0.5;exitY=1;entryX=0.5;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;strokeColor=#6C8EBF;strokeWidth=3;" edge="1" parent="1" source="s0" target="s1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s2" value="3. 'How do you want to provide this Discord bot token?' → 'Enter Discord bot token' 선택 → 토큰 붙여넣기" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=14;fontStyle=0;verticalAlign=middle;align=left;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="370" width="780" height="100" as="geometry" />
        </mxCell>
        <mxCell id="a2" value="" style="edgeStyle=none;rounded=0;html=1;endArrow=block;exitX=0.5;exitY=1;entryX=0.5;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;strokeColor=#6C8EBF;strokeWidth=3;" edge="1" parent="1" source="s1" target="s2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s3" value="4. 'Configure Discord channels access?' → Yes → 'Allowlist (recommended)' 선택" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=14;fontStyle=0;verticalAlign=middle;align=left;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="505" width="780" height="100" as="geometry" />
        </mxCell>
        <mxCell id="a3" value="" style="edgeStyle=none;rounded=0;html=1;endArrow=block;exitX=0.5;exitY=1;entryX=0.5;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;strokeColor=#6C8EBF;strokeWidth=3;" edge="1" parent="1" source="s2" target="s3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s4" value="5. 허용목록에 'OpenClaw-Test/#일반' 입력 (이때 실제로는 채널이 아닌 카테고리 ID로 잘못 매칭되는 문제가 나중에 발견됨)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=14;fontStyle=0;verticalAlign=middle;align=left;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="640" width="780" height="100" as="geometry" />
        </mxCell>
        <mxCell id="a4" value="" style="edgeStyle=none;rounded=0;html=1;endArrow=block;exitX=0.5;exitY=1;entryX=0.5;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;strokeColor=#6C8EBF;strokeWidth=3;" edge="1" parent="1" source="s3" target="s4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s5" value="6. Web search / Skills / Hooks 설정 → 전부 'Skip for now' 선택" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=14;fontStyle=0;verticalAlign=middle;align=left;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="775" width="780" height="100" as="geometry" />
        </mxCell>
        <mxCell id="a5" value="" style="edgeStyle=none;rounded=0;html=1;endArrow=block;exitX=0.5;exitY=1;entryX=0.5;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;strokeColor=#6C8EBF;strokeWidth=3;" edge="1" parent="1" source="s4" target="s5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s6" value="7. 'How do you want to hatch your agent?' → 'Hatch in Terminal (recommended)' 선택 → 에이전트 기동 (model: openai/gpt-5.5)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=14;fontStyle=0;verticalAlign=middle;align=left;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="910" width="780" height="100" as="geometry" />
        </mxCell>
        <mxCell id="a6" value="" style="edgeStyle=none;rounded=0;html=1;endArrow=block;exitX=0.5;exitY=1;entryX=0.5;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;strokeColor=#6C8EBF;strokeWidth=3;" edge="1" parent="1" source="s5" target="s6">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="troubleshoot-real" name="③ 실제 트러블슈팅 기록">
    <mxGraphModel dx="1000" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="1360" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="실행 흐름 : 실제로 막혔던 지점과 해결 과정" style="text;html=1;align=center;verticalAlign=middle;fontSize=22;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="820" height="50" as="geometry" />
        </mxCell>
        <mxCell id="s0" value="1. 디스코드 #일반 채널에 '안녕' 입력 (멘션 없이) → 무응답 (requireMention 기본값 true 때문)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=14;fontStyle=0;verticalAlign=middle;align=left;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="100" width="780" height="110" as="geometry" />
        </mxCell>
        <mxCell id="s1" value="2. '@bot20260706 안녕' 으로 멘션해서 재시도 → 그래도 무응답" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=14;fontStyle=0;verticalAlign=middle;align=left;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="245" width="780" height="110" as="geometry" />
        </mxCell>
        <mxCell id="a1" value="" style="edgeStyle=none;rounded=0;html=1;endArrow=block;exitX=0.5;exitY=1;entryX=0.5;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;strokeColor=#82B366;strokeWidth=3;" edge="1" parent="1" source="s0" target="s1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s2" value="3. 'openclaw channels status' 실행 → connected 상태는 맞지만 원인 파악 위해 로그 확인 필요" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=14;fontStyle=0;verticalAlign=middle;align=left;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="390" width="780" height="110" as="geometry" />
        </mxCell>
        <mxCell id="a2" value="" style="edgeStyle=none;rounded=0;html=1;endArrow=block;exitX=0.5;exitY=1;entryX=0.5;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;strokeColor=#82B366;strokeWidth=3;" edge="1" parent="1" source="s1" target="s2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s3" value="4. 'openclaw logs' 확인 → 'discord channels resolved: ...538058 (channel:채팅 채널)' 발견 — #일반이 아니라 상위 카테고리로 잘못 매칭됨" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=14;fontStyle=0;verticalAlign=middle;align=left;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="535" width="780" height="110" as="geometry" />
        </mxCell>
        <mxCell id="a3" value="" style="edgeStyle=none;rounded=0;html=1;endArrow=block;exitX=0.5;exitY=1;entryX=0.5;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;strokeColor=#82B366;strokeWidth=3;" edge="1" parent="1" source="s2" target="s3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s4" value="5. 브라우저 채널 URL에서 실제 #일반 채널 ID 확인 → 538060 (기존 저장된 538058과 다름)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=14;fontStyle=0;verticalAlign=middle;align=left;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="680" width="780" height="110" as="geometry" />
        </mxCell>
        <mxCell id="a4" value="" style="edgeStyle=none;rounded=0;html=1;endArrow=block;exitX=0.5;exitY=1;entryX=0.5;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;strokeColor=#82B366;strokeWidth=3;" edge="1" parent="1" source="s3" target="s4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s5" value="6. sed 명령으로 openclaw.json 안의 538058 → 538060 직접 수정" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=14;fontStyle=0;verticalAlign=middle;align=left;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="825" width="780" height="110" as="geometry" />
        </mxCell>
        <mxCell id="a5" value="" style="edgeStyle=none;rounded=0;html=1;endArrow=block;exitX=0.5;exitY=1;entryX=0.5;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;strokeColor=#82B366;strokeWidth=3;" edge="1" parent="1" source="s4" target="s5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s6" value="7. 'openclaw gateway restart' 실행 → 로그에서 'channel:일반' 으로 정상 재매칭 확인" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=14;fontStyle=0;verticalAlign=middle;align=left;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="970" width="780" height="110" as="geometry" />
        </mxCell>
        <mxCell id="a6" value="" style="edgeStyle=none;rounded=0;html=1;endArrow=block;exitX=0.5;exitY=1;entryX=0.5;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;strokeColor=#82B366;strokeWidth=3;" edge="1" parent="1" source="s5" target="s6">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s7" value="8. '@bot20260706 안녕' 재전송 → 봇이 '안녕. 나 방금 막 켜진 것 같아...' 로 정상 응답 (연동 최종 성공)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=14;fontStyle=0;verticalAlign=middle;align=left;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="1115" width="780" height="110" as="geometry" />
        </mxCell>
        <mxCell id="a7" value="" style="edgeStyle=none;rounded=0;html=1;endArrow=block;exitX=0.5;exitY=1;entryX=0.5;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;strokeColor=#82B366;strokeWidth=3;" edge="1" parent="1" source="s6" target="s7">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="tg-create" name="텔레그램 ① 봇 생성">
    <mxGraphModel dx="1000" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="텔레그램 : 봇 생성하기" style="text;html=1;align=center;verticalAlign=middle;fontSize=24;fontStyle=1;fontColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="100" y="20" width="700" height="50" as="geometry" />
        </mxCell>
        <mxCell id="s0" value="1. @BotFather 검색해서 채팅 시작" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=18;fontStyle=1;verticalAlign=middle;align=center;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="100" width="700" height="90" as="geometry" />
        </mxCell>
        <mxCell id="s1" value="2. /newbot 입력" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=18;fontStyle=1;verticalAlign=middle;align=center;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="230" width="700" height="90" as="geometry" />
        </mxCell>
        <mxCell id="a1" value="" style="edgeStyle=none;rounded=0;html=1;endArrow=block;exitX=0.5;exitY=1;entryX=0.5;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;strokeColor=#6C8EBF;strokeWidth=3;" edge="1" parent="1" source="s0" target="s1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s2" value="3. 봇 이름 정하기" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=18;fontStyle=1;verticalAlign=middle;align=center;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="360" width="700" height="90" as="geometry" />
        </mxCell>
        <mxCell id="a2" value="" style="edgeStyle=none;rounded=0;html=1;endArrow=block;exitX=0.5;exitY=1;entryX=0.5;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;strokeColor=#6C8EBF;strokeWidth=3;" edge="1" parent="1" source="s1" target="s2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="s3" value="4. 봇 username 정하기 (bot으로 끝나야 함)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=18;fontStyle=1;verticalAlign=middle;align=center;spacing=10;" vertex="1" parent="1">
